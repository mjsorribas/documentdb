 { "" : { "$maxKey" : 1 }, "t" : true }
(2 rows)

-- ======================================================================
-- SECTION 2: $eq on short (non-truncated) strings
-- ======================================================================
-- 2.1: $eq exact match — short string — index SHOULD be used
SELECT document FROM bson_aggregation_find('trunc_db', '{ "find": "trunc_coll", "filter": { "a": { "$eq": "short_string" } }, "sort": { "_id": 1 }, "collation": { "locale": "en", "strength": 1 } }');
                         document                         
----------------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : "short_string" }
 { "_id" : { "$numberInt" : "2" }, "a" : "Short_String" }
(2 rows)

SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
    EXPLAIN (COSTS OFF, ANALYZE ON, SUMMARY OFF, TIMING OFF, BUFFERS OFF) SELECT document FROM bson_aggregation_find('trunc_db', '{ "find": "trunc_coll", "filter": { "a": { "$eq": "short_string" } }, "sort": { "_id": 1 }, "collation": { "locale": "en", "strength": 1 } }')
$cmd$);
                                                                  run_explain_and_trim                                                                  
--------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort (actual rows=2 loops=1)
   Sort Key: (documentdb_api_internal.bson_orderby(document, '{ "_id" : { "$numberInt" : "1" } }'::bson, 'en-u-ks-level1'::text)) USING <<< NULLS FIRST
   Sort Method: quicksort  Memory: xxxkB
   ->  Custom Scan (DocumentDBApiExplainQueryScan) (actual rows=2 loops=1)
         namespaceName: trunc_db.trunc_coll
         indexName: idx_a_en_s1_trunc
         indexKey: {"a": 1}
         isMultiKey: false
         hasTruncation: true
         indexBounds: ["a": ["short_string", "short_string"]]
         ->  Index Scan using idx_a_en_s1_trunc on documents_2201 collection (actual rows=2 loops=1)
               Index Cond: (document @= '{ "a" : "short_string", "collation" : "en-u-ks-level1" }'::bson)
(12 rows)

