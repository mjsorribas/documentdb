    (documentdb_api_internal.bson_to_bsonindexterm(l.data)::bytea < documentdb_api_internal.bson_to_bsonindexterm(r.data)::bytea) AS matches
FROM comparable_edge_test_timestamp l, comparable_edge_test_timestamp r
WHERE l.id < r.id
ORDER BY l.id, r.id;
