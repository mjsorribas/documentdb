         indexName: a_1
         indexKey: {"a": 1}
         isMultiKey: false
         indexBounds: ["a": (500, Infinity]]
         innerScanLoops: 501 loops
         scanType: ordered
         scanKeyDetails: key 1: [(isInequality: true, estimatedEntryCount: 1500)]
         ->  Bitmap Heap Scan on documents_1401 collection (actual rows=1500 loops=1)
